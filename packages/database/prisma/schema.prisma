// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  owner
  admin
  member
}

model User {
  id            String        @id
  name          String
  email         String
  emailVerified Boolean       @default(false)
  image         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  sessions      Session[]
  accounts      Account[]
  members       Member[]
  classMembers  ClassMember[]
  invitations   Invitation[]

  githubAccounts GitHubAccount[]
  widgets        Widget[]

  @@unique([email])
  @@map("user")
}

model Session {
  id                   String   @id
  expiresAt            DateTime
  token                String
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  ipAddress            String?
  userAgent            String?
  userId               String
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  activeOrganizationId String?

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model Organization {
  id          String       @id
  name        String
  slug        String
  logo        String?
  createdAt   DateTime
  metadata    String?
  members     Member[]
  invitations Invitation[]
  courses     Course[]

  @@unique([slug])
  @@map("organization")
}

model Member {
  id             String       @id
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  role           Role         @default(member)
  createdAt      DateTime

  @@index([organizationId])
  @@index([userId])
  @@map("member")
}

model Invitation {
  id             String       @id
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  email          String
  role           Role?
  status         String       @default("pending")
  expiresAt      DateTime
  createdAt      DateTime     @default(now())
  inviterId      String
  user           User         @relation(fields: [inviterId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([email])
  @@map("invitation")
}

model Course {
  id             String  @id @default(cuid())
  organizationId String
  slug           String
  name           String
  description    String?

  rootLessonNodeId String?     @unique
  rootLessonNode   LessonNode? @relation("CourseRoot", fields: [rootLessonNodeId], references: [id])

  organization Organization @relation(fields: [organizationId], references: [id])

  lessonNodes LessonNode[] @relation("CourseToLessons")

  createdBy String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  classes Class[]

  @@unique([organizationId, slug])
  @@map("course")
}

model LessonNode {
  id    String @id @default(cuid())
  title String

  parentId String?
  parent   LessonNode?  @relation("Tree", fields: [parentId], references: [id])
  children LessonNode[] @relation("Tree")

  courseId String
  course   Course @relation("CourseToLessons", fields: [courseId], references: [id])

  rootOfCourse Course? @relation("CourseRoot")

  type    LessonNodeType
  content Json?

  order Int?

  classChildren ClassLessonNode[] @relation("NodeRoot")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([parentId])
  @@map("lesson_node")
}

enum LessonNodeType {
  course
  module
  lesson
  homework
}

model Class {
  id   String @id @default(cuid())
  name String

  courseId String
  course   Course @relation(fields: [courseId], references: [id])

  members ClassMember[]

  classLessonNodes ClassLessonNode[] @relation("ClassLessonNode")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("class")
}

model ClassMember {
  id String @id @default(cuid())

  classId String
  class   Class  @relation(fields: [classId], references: [id])

  role ClassRole

  userId String
  user   User   @relation(fields: [userId], references: [id])

  joinedAt DateTime @default(now())

  @@unique([classId, userId])
  @@map("class_member")
}

enum ClassRole {
  owner
  teacher
  student
}

model ClassLessonNode {
  id String @id @default(cuid())

  classId String
  class   Class  @relation("ClassLessonNode", fields: [classId], references: [id])

  type    ClassAddonType
  content Json?

  lessonNodeId String
  lessonNode   LessonNode @relation("NodeRoot", fields: [lessonNodeId], references: [id])

  createdAt DateTime @default(now())

  @@map("class_lesson_node")
}

enum ClassAddonType {
  lesson_note
  homework_imp
}

model GitHubAccount {
  id                String    @id @default(cuid())
  userId            String
  installationId    String    @unique // GitHub App Installation ID
  accountLogin      String // GitHub username or org name
  accountType       String // "User" or "Organization"
  accessToken       String? // Encrypted token
  accessTokenExpiry DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Widget {
  id           String   @id @default(cuid())
  userId       String
  name         String
  repoFullName String // "username/repo-name"
  repoUrl      String
  branch       String   @default("main")
  buildStatus  String   @default("pending") // pending, building, success, failed
  buildOutput  String? // JSON string of build files
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
