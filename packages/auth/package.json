{
  "name": "@repo/auth",
  "version": "1.0.0",
  "type": "module",
  "exports": {
    "./server": {
      "types": "./dist/server.d.ts",
      "default": "./dist/server.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "default": "./dist/client.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "gen": "npx @better-auth/cli generate --config ./src/auth-cli.ts --output ../database/prisma/schema.prisma"
  },
  "dependencies": {
    "@better-auth/expo": "^1.4.18",
    "@prisma/adapter-pg": "^7.2.0",
    "@repo/db": "*",
    "better-auth": "^1.4.7"
  },
  "devDependencies": {
    "typescript": "latest"
  }
}
